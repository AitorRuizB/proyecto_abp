<?xml version="1.0"?>
<robot name="robot">

<link name="base_footprint"/>

  <joint name="joint_base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
  </joint>

  <material name="azul">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="negro">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="blanco">
    <color rgba="1 1 1 1"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
      <material name="azul"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
    </collision>
  </link>

  <link name="rueda_derecha_link">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="negro"/>
      <origin rpy="1.57 0 0" xyz="0 0 0"/>
    </visual>
  </link>

  <joint name="joint_rueda_derecha" type="continuous">
    <parent link="base_link"/>
    <child link="rueda_derecha_link"/>
    <origin xyz="0 -0.225 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> </joint>

  <link name="rueda_izquierda_link">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="negro"/>
      <origin rpy="1.57 0 0" xyz="0 0 0"/>
    </visual>
  </link>

  <joint name="joint_rueda_izquierda" type="continuous">
    <parent link="base_link"/>
    <child link="rueda_izquierda_link"/>
    <origin xyz="0 0.225 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="blanco"/>
    </visual>
  </link>

  <joint name="joint_caster" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="0.2 0 -0.15" rpy="0 0 0"/>
  </joint>
  

</robot>