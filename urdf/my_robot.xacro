<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="robot_name" default="my_robot"/>

  <xacro:property name="robot_name" value="$(arg robot_name)"/>
  <xacro:property name="base_length" value="0.5"/>
  <xacro:property name="base_width" value="0.3"/>
  <xacro:property name="base_height" value="0.1"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_length" value="0.02"/>

  <!-- Posición eje Y de la rueda -->
  <xacro:property name="wheel_y" value="${base_width / 2.0 + wheel_length / 2.0}"/>
  <!--Posicion eje X de la rueda -->
  <xacro:property name="wheel_x" value="${base_length / 2.0 - wheel_radius}"/>

  <xacro:property name="caster_radius" value="${wheel_radius / 2.0}"/> <!-- El Diámetro de la rueda loca es el radio de las ruedas motrices -->
  <xacro:property name="caster_joint_x" value="-0.2"/>
  <xacro:property name="caster_joint_y" value="0.0"/>
  <xacro:property name="caster_joint_z" value="${-(base_height / 2.0 + caster_radius)}"/>

  <!--Macro de inercia de un octaedro-->
  <xacro:macro name="box_inertia" params="m x y z o_xyz o_rpy" >
    <inertial>
      <mass value="${m}" />
      <origin xyz="${o_xyz}" rpy="${o_rpy}" />
      <inertia ixx="${m / 12.0*(y*y + z*z)}" ixy="0" ixz="0"
               iyy="${m / 12.0*(x*x + z*z)}" iyz="0"
               izz="${m / 12.0*(x*x + y*y)}" />
    </inertial>
  </xacro:macro>

  <!--Macro de inercia de un cilindro-->
  <xacro:macro name="cylinder_inertia" params="m r h o_xyz o_rpy">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <inertia ixx="${m / 12.0 * (3*r*r + h*h)}" ixy="0" ixz="0"
               iyy="${m / 12.0 * (3*r*r + h*h)}" iyz="0"
               izz="${m / 2.0 * r*r}"/>
    </inertial>
  </xacro:macro>

  <!--Macro de inercia de una esfera-->
  <xacro:macro name="sphere_inertia" params="m r o_xyz o_rpy">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <inertia ixx="${2.0/5.0 * m * r*r}" ixy="0" ixz="0"
               iyy="${2.0/5.0 * m * r*r}" iyz="0"
               izz="${2.0/5.0 * m * r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="${robot_name}_blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <!-- Llamada a la macro-->
    <xacro:box_inertia m="5.0" x="${base_length}" y="${base_width}"
        z="${base_height}" o_xyz="0 0 ${base_height / 2.0}" o_rpy="0 0 0" />
  </link>
  
  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_length}"
                            o_xyz="0 0 0" o_rpy="1.5707963 0 0" />
  </link>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_length}"
                            o_xyz="0 0 0" o_rpy="1.5707963 0 0" />
  </link>

  <!-- Caster Wheel -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="0.1" r="${caster_radius}"
                          o_xyz="0 0 0" o_rpy="0 0 0" />
  </link>

  <!-- Joints -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="${wheel_x} ${wheel_y} -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="${wheel_x} -${wheel_y} -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${caster_joint_x} ${caster_joint_y} ${caster_joint_z}" rpy="0 0 0"/>
  </joint>

  <!-- Sensores -->
  <xacro:include filename="$(find robot_bringup)/urdf/lidar.xacro" />
  <xacro:include filename="$(find robot_bringup)/urdf/camera.xacro" />

  <xacro:lidar_sensor parent="base_link" namespace="$(arg robot_name)" origin_xyz="0.2 0 0.1" origin_rpy="0 0 0"/>
  <xacro:camera_sensor parent="base_link" namespace="$(arg robot_name)" origin_xyz="0.2 0 0.175" origin_rpy="0 0 0"/>

  <!-- Incluir plugins de Gazebo -->
  <xacro:include filename="$(find robot_bringup)/urdf/gz_plugin.xacro" />

</robot>