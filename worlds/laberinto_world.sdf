      <static>true</static>
      <pose>6.05 -0.6 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>3.9 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>3.9 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
