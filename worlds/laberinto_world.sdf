      <pose>-7.4 -4.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.2 9 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.2 9 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Obstacle 2 (Wall segment) -->
    <model name="hall_W_obs2">
      <static>true</static>
      <pose>-8 -5 0.5 0 0 1.5708</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.5 0.2 1</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.5 0.2 1</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material></visual></link>
    </model>
    <!-- Turn East Wall (closes off the south path, forces east turn) -->
    <model name="hall_W_turn_wall_S">
      <static>true</static>
      <pose>-8 -8.1 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>1.4 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.4 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Segment 3 (East to shelf) -->
    <model name="hall_W_seg3_wall_N">
      <static>true</static>
      <pose>1.0 -7.4 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>18 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>18 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <model name="hall_W_seg3_wall_S">
