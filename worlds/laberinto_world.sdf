    </model>
    <!-- Obstacle 1 (Pillar) -->
    <model name="hall_E_obs1">
      <static>true</static>
      <pose>6.5 0 0.5 0 0 1.5708</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.5 0.2 1</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.5 0.2 1</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material></visual></link>
    </model>
    <!-- Turn North Wall (closes off the east path, forces north turn) -->
    <model name="hall_E_turn_wall_E">
      <static>true</static>
      <pose>8.1 0 1 0 0 1.5708</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.2 1.4 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.2 1.4 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Segment 2 (North to shelf) -->
    <model name="hall_E_seg2_wall_W">
      <static>true</static>
      <pose>8.6 4.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.2 9 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.2 9 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <model name="hall_E_seg2_wall_E">
      <static>true</static>
      <pose>9.4 4.5 1 0 0 0</pose>
