    </model>
    <!-- Obstacle 1 (Pillar) -->
    <model name="hall_S_obs1">
      <static>true</static>
      <pose>0 -6.5 0.5 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.2 0.5 1</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.2 0.5 1</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material></visual></link>
    </model>
    <!-- Turn West Wall (closes off the south path, forces west turn) -->
    <model name="hall_S_turn_wall_S">
      <static>true</static>
      <pose>0 -8.1 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>1.4 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.4 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Segment 2 (West to shelf) -->
    <model name="hall_S_seg2_wall_N">
      <static>true</static>
      <pose>-4.5 -7.4 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>9 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>9 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <model name="hall_S_seg2_wall_S">
      <static>true</static>
      <pose>-4.5 -8.6 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>9 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>9 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Obstacle 2 (Wall segment) -->
    <model name="hall_S_obs2">
      <static>true</static>
      <pose>-5 -8 0.5 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.5 0.2 1</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.5 0.2 1</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material></visual></link>
    </model>

    <!-- ===================================================== -->
    <!-- WEST HALLWAY (to Yellow Shelf at 10, -8)              -->
    <!-- Hallway width: 1.0m. Walls are 0.2m thick.            -->
    <!-- Path: West (from x=-4.1 to x=-8.0), then South (from y=0 to y=-8), then East (from x=-8 to x=10) -->
    <!-- ===================================================== -->

    <!-- Segment 1 (West) -->
    <model name="hall_W_seg1_wall_S">
      <static>true</static>
      <pose>-6.05 -0.6 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>3.9 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>3.9 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <model name="hall_W_seg1_wall_N">
      <static>true</static>
      <pose>-6.05 0.6 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>3.9 0.2 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>3.9 0.2 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Obstacle 1 (Pillar) -->
    <model name="hall_W_obs1">
      <static>true</static>
      <pose>-6.5 0 0.5 0 0 1.5708</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.5 0.2 1</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.5 0.2 1</size></box></geometry><material><ambient>0.4 0.4 0.4 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material></visual></link>
    </model>
    <!-- Turn South Wall (closes off the west path, forces south turn) -->
    <model name="hall_W_turn_wall_W">
      <static>true</static>
      <pose>-8.1 0 1 0 0 1.5708</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.2 1.4 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.2 1.4 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
    </model>
    <!-- Segment 2 (South) -->
    <model name="hall_W_seg2_wall_W">
      <static>true</static>
      <pose>-8.6 -4.5 1 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.2 9 2</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.2 9 2</size></box></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual></link>
